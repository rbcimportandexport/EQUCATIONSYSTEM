# RBC Education System — Backend Server Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/rbc_education?retryWrites=true&w=majority

# JWT Secret Key (change this to a random long string in production)
JWT_SECRET=rbc_import_export_academy_super_secret_2026

# JWT Token Expiry
JWT_EXPIRE=7d

# Server Port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
